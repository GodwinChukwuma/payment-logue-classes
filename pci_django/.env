# =============================================================================
#  PCI-DSS Transaction API — Environment Variables
#  Copy this file to .env and fill in EVERY value before starting the server.
#  NEVER commit the filled-in .env to version control.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Credentials for the dedicated pci_user database account.
# PCI-DSS Req 8.2: credentials stored in env vars, never hardcoded.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pci_transactions
DB_USER=pci_user
DB_PASSWORD=user
# CREATE USER pci_user WITH PASSWORD 'user';
# CREATE DATABASE pci_transactions OWNER pci_user;
# GRANT ALL PRIVILEGES ON DATABASE pci_transactions TO pci_user;

# ── AES-256 Encryption Key ────────────────────────────────────────────────────
# Used to encrypt PAN and Expiry Date before storing in PostgreSQL.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Must be exactly 64 hex characters (= 32 bytes = AES-256).
# PCI-DSS Req 3.5: protect keys used to secure stored account data.
# python -c "import secrets; print(secrets.token_hex(32))"
AES_ENCRYPTION_KEY=6322da6f6bbaae22a32c10bdd07e1d025dcfd8dce24cc8b5045b45aeb9f08928

# ── JWT Authentication ────────────────────────────────────────────────────────
# Secret used to sign and verify JWT tokens.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=KAYWy7ZQb9EHxGPkaVXPhsdWiiTi4zY6dMJU1TXpsxa

# Token expiry in minutes (access token)
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30

# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=rzywzq9i9cjs6*n21y*0npdg&=wqgxk-j76w&u&q^=ox1gyn60

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Maximum requests per minute per IP on the /processTransaction endpoint.
# PCI-DSS Req 6.4.1: protect public-facing application from abuse.
RATE_LIMIT_PER_MINUTE=30

# ── Logging ───────────────────────────────────────────────────────────────────
# Path to audit log file (relative to project root).
# PCI-DSS Req 10.2: implement audit trails.
LOG_FILE=logs/transactions.log
LOG_LEVEL=DEBUG

# ── TLS (production) ─────────────────────────────────────────────────────────
# Paths to TLS certificate and private key.
# PCI-DSS Req 4.2.1: encrypt PAN in transit.
# Leave blank to run plain HTTP in development.
TLS_CERT_PATH=certs/server.crt
TLS_KEY_PATH=certs/server.key

API_KEY=test-key

DEBUG=True
ENVIRONMENT=development

